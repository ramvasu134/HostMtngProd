{
  "name": "host-mtng-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Capacitor wrapper for the Host Mtng Spring Boot web app. The mobile app loads the Render-hosted production URL inside a native WebView — no separate codebase, no separate database.",
  "scripts": {
    "cap:sync": "cap sync",
    "cap:android": "cap add android",
    "cap:ios": "cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "build:android:debug": "cd android && gradlew assembleDebug",
    "build:android:release": "cd android && gradlew bundleRelease"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2"
  }
}
